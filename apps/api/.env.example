NODE_ENV="development"
API_PORT=4000
API_PREFIX="api"
WEB_ORIGIN="http://localhost:3000"
DATABASE_URL="postgresql://homeschool:homeschool@localhost:5432/homeschool_platform?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="1d"
SEED_ADMIN_EMAIL="admin@local.test"
SEED_TEACHER_EMAIL="teacher@local.test"
SEED_STUDENT_EMAIL="student@local.test"
SEED_DEFAULT_PASSWORD="LocalV1Password2026!"

# Storage
STORAGE_DRIVER="supabase"
SUPABASE_URL="https://example-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace-with-supabase-service-role-key"
SUPABASE_STORAGE_BUCKET="homeschool-private"
